# LLM backend: 'anthropic' (default) or 'openai'
LLM_PROVIDER=anthropic

# Required when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# Required when LLM_PROVIDER=openai
OPENAI_API_KEY=

# ContentDrips credentials for slide image rendering
CONTENTDRIPS_API_KEY=
CONTENTDRIPS_TEMPLATE_ID=

# Optional: override ContentDrips API base URL
CONTENTDRIPS_API_BASE=https://generate.contentdrips.com
